{
  "expo": {
    "name": "Production System",
    "slug": "brekaz-producao",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "productionsystem",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "br.com.brekaz.producao",
      "infoPlist": {
        "NSCameraUsageDescription": "O Production System precisa acessar a câmera para realizar a auditoria visual e prova de vida da equipe.",
        "NSLocationWhenInUseUsageDescription": "O Production System utiliza sua localização para mapear os pontos de colheita e gerenciar os talhões no mapa da fazenda.",
        "NSPhotoLibraryUsageDescription": "O Production System precisa de acesso à galeria para salvar e compartilhar os relatórios de auditoria em PDF."
      }
    },
    "android": {
      "package": "br.com.brekaz.producao",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "O Production System precisa acessar a câmera para realizar a auditoria visual (Prova de Vida) da equipe no campo."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "O Production System precisa da sua localização para registrar as coordenadas exatas da produção no campo."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "81aa797f-aa39-4d88-ae0b-fa8caab957a7"
      }
    },
    "owner": "brekaz"
  }
}